// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// DATA ROOM MODELS
// ============================================================================

// User roles for the data room
enum UserRole {
  SUPER_ADMIN
  ADMIN
  REVIEWER
  VIEWER
}

// Document access tiers
enum AccessTier {
  TEASER      // Public marketing materials
  QUALIFIED   // NDA required, qualified investors only
  TRANSACTION // Full due diligence, deal-specific
}

// Document status
enum DocumentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  ARCHIVED
  REVOKED
}

// Deal room status
enum DealRoomStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

// Data Room Users
model DataRoomUser {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  company       String?
  title         String?
  phone         String?
  role          UserRole    @default(VIEWER)
  isActive      Boolean     @default(true)
  mfaEnabled    Boolean     @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relations
  accessGrants  AccessGrant[]
  auditLogs     AuditLog[]
  ndaSignatures NDASignature[]
  sessions      UserSession[]
  
  @@map("data_room_users")
}

// User sessions for security tracking
model UserSession {
  id           String   @id @default(cuid())
  userId       String
  user         DataRoomUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@map("user_sessions")
}

// Deal Rooms - separate spaces for different transactions
model DealRoom {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      DealRoomStatus  @default(ACTIVE)
  validFrom   DateTime?
  validUntil  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  // Relations
  documents   Document[]
  accessGrants AccessGrant[]
  ndaTemplates NDATemplate[]
  
  @@map("deal_rooms")
}

// Documents in the data room
model Document {
  id             String         @id @default(cuid())
  dealRoomId     String
  dealRoom       DealRoom       @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  
  // Document metadata
  title          String
  description    String?
  fileName       String
  fileSize       Int
  mimeType       String
  s3Key          String         // S3 object key
  s3VersionId    String?        // For versioning
  
  // Access control
  accessTier     AccessTier     @default(QUALIFIED)
  status         DocumentStatus @default(DRAFT)
  
  // Watermarking
  watermarkText  String?
  hasWatermark   Boolean        @default(false)
  
  // Classification
  category       String?        // e.g., "Financial", "Legal", "Technical"
  tags           String?        // JSON array of tags
  
  // Version tracking
  version        Int            @default(1)
  parentDocId    String?
  
  // Timestamps
  uploadedBy     String?        // User ID
  reviewedBy     String?        // User ID who approved
  reviewedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  // Relations
  accessGrants   DocumentAccess[]
  auditLogs      AuditLog[]
  
  @@map("documents")
}

// NDA Templates for different deal rooms
model NDATemplate {
  id          String    @id @default(cuid())
  dealRoomId  String
  dealRoom    DealRoom  @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  name        String
  content     String    // NDA text/HTML content
  version     Int       @default(1)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  signatures  NDASignature[]
  
  @@map("nda_templates")
}

// NDA Signatures tracking
model NDASignature {
  id            String      @id @default(cuid())
  ndaTemplateId String
  ndaTemplate   NDATemplate @relation(fields: [ndaTemplateId], references: [id], onDelete: Cascade)
  userId        String
  user          DataRoomUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  signedAt      DateTime    @default(now())
  ipAddress     String?
  userAgent     String?
  
  @@unique([ndaTemplateId, userId])
  @@map("nda_signatures")
}

// Access grants - who can access what
model AccessGrant {
  id          String      @id @default(cuid())
  userId      String
  user        DataRoomUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealRoomId  String
  dealRoom    DealRoom    @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  
  // Access level for this deal room
  accessTier  AccessTier  @default(QUALIFIED)
  
  // Time-limited access
  grantedAt   DateTime    @default(now())
  expiresAt   DateTime?
  grantedBy   String?     // User ID of admin who granted
  
  isActive    Boolean     @default(true)
  
  @@unique([userId, dealRoomId])
  @@map("access_grants")
}

// Document-level access overrides
model DocumentAccess {
  id          String    @id @default(cuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  // Either userId or accessTier must be set
  userId      String?   // Specific user access
  accessTier  AccessTier? // Tier-based access
  
  canView     Boolean   @default(true)
  canDownload Boolean   @default(false)
  canPrint    Boolean   @default(false)
  
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  
  @@map("document_access")
}

// Comprehensive audit logging
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        DataRoomUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Action details
  action      String   // VIEW, DOWNLOAD, UPLOAD, DELETE, GRANT_ACCESS, etc.
  resource    String   // Resource type: DOCUMENT, DEAL_ROOM, USER, etc.
  resourceId  String?  // ID of the affected resource
  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  
  // Request metadata
  ipAddress   String?
  userAgent   String?
  details     String?  // JSON string with additional details
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// Access requests from potential investors
model AccessRequest {
  id            String      @id @default(cuid())
  email         String
  name          String
  company       String
  title         String?
  phone         String?
  dealRoomId    String?
  
  // Request status
  status        String      @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedTier AccessTier  @default(TEASER)
  
  // Message from requester
  message       String?
  
  // Admin notes
  adminNotes    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@map("access_requests")
}

// ============================================================================
// LEGACY MODELS (keeping for reference)
// ============================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
